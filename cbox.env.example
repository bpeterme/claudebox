# claudebox user configuration
# Copy to ~/.cbox.env and uncomment/customize the values you need.
# This file is sourced as a shell script, so variable expansion works.
#
# All settings are optional — cbox works without this file using the defaults shown below.

# ─── image & container ────────────────────────────────────────────────────────

# CBOX_IMAGE="claudebox"            # Docker image name (default: claudebox)
# CBOX_LABEL="cbox.project=true"   # Label applied to all cbox containers
# CBOX_KEEPALIVE_SECONDS=600       # Seconds before auto-stop in keepalive mode

# ─── host paths ───────────────────────────────────────────────────────────────

# Per-project container config files (.claude-<name>.json), one per project
# Defaults to $XDG_DATA_HOME/cbox (~/.local/share/cbox if XDG_DATA_HOME is unset)
# CBOX_DATA_DIR="$HOME/.local/share/cbox"

# Claude Code config directory — mounted into the container as ~/.claude
# CBOX_CLAUDE_DIR="$HOME/.claude"

# Host ~/.config to mount into the container as ~/.config (normal mode only)
# CBOX_HOST_CONFIG_DIR="$HOME/.config"

# Share directory — mounted as ~/share inside the container; cleared on exit
# Defaults to /tmp/cbox-<user>; override if your container runtime can't mount /tmp
# CBOX_SHARE_DIR="/tmp/cbox-$USER"

# ─── optional mounts (leave unset to disable) ─────────────────────────────────

# SSH directory to mount as ~/.ssh inside the container (normal mode only)
# CBOX_SSH_DIR="$HOME/.ssh"

# Path to a .zshrc to source inside the container as ~/.zshrc.global
# CBOX_ZSHRC="$HOME/.config/dotfiles/zshrc.global"

# Directory to mount read-only inside the container at the same path
# CBOX_DOTFILES_DIR="$HOME/.config/dotfiles"

# ─── build ────────────────────────────────────────────────────────────────────

# Directory containing the dockerfile (default: directory of cbox.sh)
# CBOX_BUILD_DIR="$HOME/path/to/claudebox"

# Set to 1 to include Playwright + Chromium in the image (~1.3 GB extra)
# BUILD_PLAYWRIGHT=0
