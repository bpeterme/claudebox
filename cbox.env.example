# claudebox user configuration
# Copy to ~/.config/claudebox/cbox.env and uncomment/customize the values you need.
# If $XDG_CONFIG_HOME is set, use $XDG_CONFIG_HOME/claudebox/cbox.env instead.
# This file is sourced as a shell script, so variable expansion works.
#
# All settings are optional — cbox works without this file using the defaults shown below.

# ─── output ───────────────────────────────────────────────────────────────────

# Show full output: npm updates, sync messages, MCP proxy status (default: 0)
# Can also be set per-invocation with: cbox -v
# CBOX_VERBOSE=0

# ─── image & container ────────────────────────────────────────────────────────

# CBOX_IMAGE="claudebox"            # Docker image name (default: claudebox)
# CBOX_LABEL="cbox.project=true"   # Label applied to all cbox containers
# CBOX_KEEPALIVE_SECONDS=600       # Seconds before auto-stop in keepalive mode

# ─── host paths ───────────────────────────────────────────────────────────────

# Per-project container config files (.claude-<name>.json), one per project
# Defaults to $XDG_DATA_HOME/claudebox (~/.local/share/claudebox if XDG_DATA_HOME is unset)
# CBOX_DATA_DIR="$HOME/.local/share/claudebox"

# Claude Code config directory — mounted into the container as ~/.claude
# CBOX_CLAUDE_DIR="$HOME/.claude"

# Host config dir to mount into the container as ~/.config (normal mode only)
# Defaults to $XDG_CONFIG_HOME (~/.config if XDG_CONFIG_HOME is unset)
# CBOX_HOST_CONFIG_DIR="$HOME/.config"

# Share directory — mounted as ~/share inside the container; cleared on exit
# Defaults to ~/.cache/claudebox/share (respects $XDG_CACHE_HOME if set)
# CBOX_SHARE_DIR="$HOME/.cache/claudebox/share"

# ─── optional mounts (leave unset to disable) ─────────────────────────────────

# SSH directory to mount as ~/.ssh inside the container (normal mode only)
# CBOX_SSH_DIR="$HOME/.ssh"

# Path to a .zshrc to source inside the container as ~/.zshrc.global
# CBOX_ZSHRC="$HOME/.zshrc"

# ─── build ────────────────────────────────────────────────────────────────────

# Directory containing the dockerfile (default: directory of cbox.sh)
# CBOX_BUILD_DIR="$HOME/path/to/claudebox"

# Set to 1 to include Playwright + Chromium in the image (~1.3 GB extra)
# BUILD_PLAYWRIGHT=0

# ─── voice mode ───────────────────────────────────────────────────────────────

# Enable Claude Code voice mode (/voice) inside the container.
# Requires PulseAudio on the host: brew install pulseaudio
# PulseAudio starts and stops automatically with each cbox session.
# Requires a Claude.ai account (not compatible with raw API key auth).
# CBOX_AUDIO=1

# ─── companion tools ──────────────────────────────────────────────────────────

# claudedot — cross-machine config + history sync via git
# Install: brew tap bpeterme/claudedot && brew install bpeterme/claudedot/claudedot
# Set up:  cdot config

# flux — large-file routing for your projects (git + R2 storage)
# Install: brew tap bpeterme/flux && brew install bpeterme/flux/flux
# Set up:  flux setup
